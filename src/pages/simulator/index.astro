---
import '../../styles/global.css';
import AppHeader from '../../components/AppHeader.astro';
import Navigation from '../../components/Navigation.astro';
import SimControls from '../../components/SimControls.astro';
import MontePanel from '../../components/panels/MontePanel.astro';
import GroupsPanel from '../../components/panels/GroupsPanel.astro';
import FixturePanel from '../../components/panels/FixturePanel.astro';
import BracketPanel from '../../components/panels/BracketPanel.astro';
import BrowserPanel from '../../components/panels/BrowserPanel.astro';
import JourneyPanel from '../../components/panels/JourneyPanel.astro';
import SquadsPanel from '../../components/panels/SquadsPanel.astro';
import PowerPanel from '../../components/panels/PowerPanel.astro';
import VotePanel from '../../components/panels/VotePanel.astro';
import OnboardingModal from '../../components/modals/OnboardingModal.astro';
import MatchModal from '../../components/modals/MatchModal.astro';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <meta name="generator" content={Astro.generator} />

    <title>WC 2026 Simulator — BapLab</title>
    <meta name="description" content="Run thousands of 2026 FIFA World Cup simulations. 48 teams, 1,104 players, Annex C bracket logic, and full match events every sim." />
    <link rel="canonical" href="https://baplab.net/simulator/" />

    <!-- OpenGraph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content="https://baplab.net/simulator/" />
    <meta property="og:title"       content="WC 2026 Simulator — BapLab" />
    <meta property="og:description" content="Run thousands of 2026 FIFA World Cup simulations. 48 teams, 1,104 players, Annex C bracket logic, and full match events every sim." />
    <meta property="og:image"       content="https://baplab.net/og-image.png" />
    <meta name="twitter:card"       content="summary_large_image" />
  </head>
  <body>
    <OnboardingModal />

    <div class="shell">
      <AppHeader />
      <div style="padding:8px 16px 4px">
        <div class="ptit">2026 FIFA World Cup Simulator</div>
        <div class="psub" data-i18n="header.subtitle">48 teams, 1,104 players, Annex C 495 scenarios, Match report every sim, v4.2</div>
      </div>
      <Navigation />
      <SimControls />

      <MontePanel />
      <GroupsPanel />
      <FixturePanel />
      <BracketPanel />
      <BrowserPanel />
      <JourneyPanel />
      <SquadsPanel />
      <PowerPanel />
      <VotePanel />
    </div>

    <MatchModal />

    <footer style="text-align:center;padding:22px 0 32px;font-size:12px;color:#bbb;border-top:1px solid #eee;margin-top:12px;line-height:2">
      <div style="display:flex;align-items:center;justify-content:center;gap:18px;flex-wrap:wrap;margin-bottom:6px">
        <a href="/" style="color:#555;text-decoration:none;font-weight:500">← BapLab</a>
        <a href="/blog/" style="color:#555;text-decoration:none;font-weight:500">Blog</a>
        <a href="mailto:baplab.net@gmail.com" style="color:#555;text-decoration:none;font-weight:500;display:inline-flex;align-items:center;gap:4px">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Contact Us
        </a>
      </div>
      <span style="color:#ccc">WC 2026 Simulator &mdash; Not affiliated with FIFA &mdash; <a href="/" style="color:#999;text-decoration:none">BapLab</a></span>
    </footer>

    <script>
      import '../../scripts/main.js';
    </script>
  </body>
</html>
