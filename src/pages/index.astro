---
import '../styles/lab.css';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />

  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/favicon.png" />

  <meta name="generator" content={Astro.generator} />

  <!-- Primary SEO -->
  <title>BapLab | World Cup 2026 Simulator &amp; AI Experiments</title>
  <meta name="description" content="Join BapLab's community. Build your 2026 World Cup bracket with our interactive FIFA prediction engine. Explore thousands of probabilistic AI-driven tournament outcomes, automation lab experiments, and data stories." />
  <meta name="keywords" content="2026 FIFA World Cup simulator, WC2026 bracket, football prediction engine, AI sports analysis, Monte Carlo simulation, BapLab" />
  <link rel="canonical" href="https://baplab.net/" />

  <!-- OpenGraph -->
  <meta property="og:type"         content="website" />
  <meta property="og:url"          content="https://baplab.net/" />
  <meta property="og:site_name"    content="BapLab" />
  <meta property="og:title"        content="BapLab | World Cup 2026 Simulator &amp; AI Experiments" />
  <meta property="og:description"  content="Join BapLab's community. Build your 2026 World Cup bracket with our interactive FIFA prediction engine. Explore thousands of probabilistic AI-driven tournament outcomes, automation lab experiments, and data stories." />
  <meta property="og:image"        content="https://baplab.net/og-image.png" />
  <meta property="og:image:alt"    content="BapLab - WC 2026 Simulator showing tournament probability grid" />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter / X -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content="BapLab | World Cup 2026 Simulator" />
  <meta name="twitter:description" content="The most advanced FIFA WC 2026 simulator. 48 teams, 1,104 players, probabilistic forecasts." />
  <meta name="twitter:image"       content="https://baplab.net/og-image.png" />

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "BapLab WC 2026 Simulator",
    "url": "https://baplab.net/world-cup-2026-simulator/",
    "applicationCategory": "SportsApplication",
    "operatingSystem": "Web",
    "description": "Advanced Monte Carlo simulator for the 2026 FIFA World Cup. Covers 48 teams, 1,104 real players, Annex C bracket logic, and full match event generation.",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "author": { "@type": "Organization", "name": "BapLab", "url": "https://baplab.net" }
  })}></script>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "BapLab",
    "url": "https://baplab.net"
  })}></script>

  <style>
    /* ── Bento grid ──────────────────────────────────────── */
    .bento {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
      max-width: 1160px;
      margin: 0 auto;
      padding: 16px;
    }
    .cell {
      background: var(--color-card);
      border: 1px solid var(--color-line);
      border-radius: var(--radius-card);
      padding: 24px;
      position: relative;
      overflow: hidden;
      transition: border-color .2s, box-shadow .2s;
    }
    .cell:hover {
      border-color: rgba(0,212,255,.2);
      box-shadow: 0 0 20px rgba(0,212,255,.04);
    }

    /* Simulator hero tile */
    .cell-sim {
      grid-column: 1 / 3;
      grid-row: 1 / 3;
      background: linear-gradient(135deg, #0d1520 0%, #0f1c28 60%, #0a1018 100%);
      min-height: 340px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    /* Patreon card */
    .cell-patreon {
      background: linear-gradient(135deg, #130a10 0%, #1c0818 100%);
      border-color: #2a0a20;
    }
    .cell-patreon:hover {
      border-color: rgba(212,0,255,.3);
      box-shadow: 0 0 20px rgba(212,0,255,.05);
    }

    .cell-placeholder { background: var(--color-card-2); min-height: 130px; }
    .cell-blog { grid-column: 1 / -1; }

    /* Tag pills */
    .tag {
      display: inline-block;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .1em;
      text-transform: uppercase;
      padding: 3px 8px;
      border-radius: 4px;
      margin-bottom: 10px;
    }
    .tag-cy  { background: rgba(0,212,255,.12); color: #00d4ff; border: 1px solid rgba(0,212,255,.2); }
    .tag-mg  { background: rgba(212,0,255,.12); color: #d400ff; border: 1px solid rgba(212,0,255,.2); }
    .tag-blue { background: rgba(100,160,255,.1); color: #80b3ff; border: 1px solid rgba(100,160,255,.18); }
    .tag-purple { background: rgba(150,80,255,.1); color: #b580ff; border: 1px solid rgba(150,80,255,.18); }
    .tag-pink { background: rgba(255,80,160,.1); color: #ff6ab4; border: 1px solid rgba(255,80,160,.18); }

    .cell-title {
      font-size: 20px;
      font-weight: 700;
      color: #e0eef5;
      margin-bottom: 8px;
      line-height: 1.25;
    }
    .cell-desc { font-size: 13px; color: var(--color-muted); line-height: 1.6; flex: 1; }

    /* CTA buttons */
    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 20px;
      padding: 10px 20px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: .02em;
      cursor: pointer;
      transition: all .15s;
      text-decoration: none;
      border: none;
    }
    .cta-cy {
      background: #00d4ff;
      color: #001823;
    }
    .cta-cy:hover {
      background: #00b8e6;
      box-shadow: 0 0 16px rgba(0,212,255,.35);
    }
    .cta-mg {
      background: #d400ff;
      color: #f8e8ff;
    }
    .cta-mg:hover {
      background: #b800e6;
      box-shadow: 0 0 16px rgba(212,0,255,.35);
    }
    .cta-ghost {
      background: transparent;
      color: var(--color-muted);
      border: 1px solid var(--color-line);
    }
    .cta-ghost:hover {
      color: var(--color-text);
      border-color: rgba(0,212,255,.3);
    }

    /* Stats strip */
    .stats-strip { display: flex; gap: 20px; flex-wrap: wrap; margin: 16px 0; }
    .stat { font-size: 11px; color: var(--color-muted); }
    .stat b { color: #00d4ff; font-weight: 700; font-size: 13px; display: block; }

    /* Waveform decoration */
    .waveform {
      position: absolute;
      bottom: 0; right: 0;
      width: 200px; height: 90px;
      opacity: .05; pointer-events: none;
    }

    /* Coming-soon badge */
    .soon {
      position: absolute; top: 14px; right: 14px;
      font-size: 9px; font-weight: 700;
      letter-spacing: .08em; text-transform: uppercase;
      padding: 2px 7px; border-radius: 4px;
      background: rgba(255,255,255,.03); color: #334;
      border: 1px solid #1a2030;
    }

    /* ── Responsive ──────────────────────────────────────── */
    @media (max-width: 800px) {
      .bento { grid-template-columns: repeat(2, 1fr); gap: 10px; padding: 12px; }
      .cell-sim { grid-column: 1 / -1; grid-row: auto; min-height: 280px; }
      .cell-blog { grid-column: 1 / -1; }
    }
    @media (max-width: 520px) {
      .bento { grid-template-columns: 1fr; gap: 8px; padding: 10px; }
      .cell-blog { grid-column: auto; }
      .cell-sim { min-height: 240px; }
      .cell-title { font-size: 17px; }
    }

    /* ── Nav ─────────────────────────────────────────────── */
    .lab-nav {
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 24px;
      border-bottom: 1px solid var(--color-line);
    }
    .lab-logo {
      display: inline-flex; align-items: center; gap: 10px;
      text-decoration: none;
    }
    .lab-logo img { height: 36px; width: auto; border-radius: 7px; }
    .lab-logo-text {
      font-size: 18px; font-weight: 800; letter-spacing: .04em; color: #e0eef5;
    }
    .lab-logo-text span { color: #00d4ff; }
    .lab-nav-links { display: flex; align-items: center; gap: 20px; }
    .lab-nav-links a {
      font-size: 13px; font-weight: 500; color: var(--color-muted);
      text-decoration: none; transition: color .15s;
    }
    .lab-nav-links a:hover { color: #00d4ff; }
    .lab-nav-links a.active { color: #e0eef5; }

    /* ── Footer ──────────────────────────────────────────── */
    .lab-footer {
      text-align: center; padding: 28px 16px 36px;
      font-size: 11px; color: #1e2a35;
      border-top: 1px solid var(--color-line); margin-top: 8px;
    }
    .lab-footer a { color: #2a4050; text-decoration: none; }
    .lab-footer a:hover { color: var(--color-muted); }
  </style>
</head>
<body>

  <!-- Nav -->
  <nav class="lab-nav">
    <a href="/" class="lab-logo" aria-label="BapLab home">
      <img src="/logo-wide.png" alt="BapLab" style="height:2rem;object-fit:contain" />
    </a>
    <div class="lab-nav-links">
      <a href="/" class="active">Home</a>
      <a href="/world-cup-2026-simulator/" target="_blank" rel="noopener noreferrer">Simulator</a>
      <a href="/blog/">Blog</a>
      <a href="https://www.patreon.com/c/BapLab" target="_blank" rel="noopener noreferrer" style="color:#d400ff">Patreon</a>
    </div>
  </nav>

  <!-- Bento Grid -->
  <main class="bento">

    <!-- 1. Featured: WC 2026 Simulator -->
    <article class="cell cell-sim glow-box" aria-label="WC 2026 Simulator">
      <div>
        <span class="tag tag-cy">⚽ Featured</span>
        <h1 class="cell-title" style="font-size:26px">
          2026 FIFA World Cup<br />
          <span style="color:#00d4ff" class="glow-cy">Simulator</span>
        </h1>
        <p class="cell-desc">
          The most advanced probabilistic FIFA WC 2026 simulator.
          Monte Carlo engine, 48 teams, 1,104 real players, Annex C bracket logic, full match reports every sim.
        </p>
        <div class="stats-strip">
          <div class="stat"><b>48</b>Teams</div>
          <div class="stat"><b>1,104</b>Players</div>
          <div class="stat"><b>495</b>Scenarios</div>
          <div class="stat"><b>104</b>Matches/sim</div>
        </div>
        <a
          href="/world-cup-2026-simulator/"
          target="_blank"
          rel="noopener noreferrer"
          class="cta-btn cta-cy"
          aria-label="Launch the WC 2026 Simulator in a new tab"
        >
          Launch Simulator
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Decorative waveform -->
      <svg class="waveform" viewBox="0 0 200 90" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <polyline points="0,45 10,20 20,60 30,30 40,55 50,15 60,50 70,35 80,65 90,25 100,50 110,40 120,60 130,20 140,55 150,30 160,50 170,10 180,45 190,35 200,45" stroke="#00d4ff" stroke-width="2" fill="none"/>
      </svg>
    </article>

    <!-- 2. Patreon CTA -->
    <article class="cell cell-patreon glow-box-hover" aria-label="Support BapLab on Patreon">
      <span class="tag tag-mg">❤️ Support</span>
      <h2 class="cell-title" style="font-size:16px">Support the Lab</h2>
      <p class="cell-desc" style="color:#5a3a5a;font-size:12px">
        Fuel the next generation of simulations and automation tools. Help us keep the servers running, and unlock early access to new projects.
      </p>
      <a
        href="https://www.patreon.com/c/BapLab"
        target="_blank"
        rel="noopener noreferrer"
        class="cta-btn cta-mg"
        aria-label="Support BapLab on Patreon"
      >
        Become a Patron
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </article>

    <!-- 3. AI Experiments -->
    <article class="cell cell-placeholder glow-box-hover" aria-label="AI Experiments - coming soon">
      <span class="soon">Coming Soon</span>
      <span class="tag tag-blue">🤖 AI</span>
      <h2 class="cell-title" style="font-size:16px">AI Experiments</h2>
      <p class="cell-desc">Generative models, LLM pipelines, and machine-learning experiments applied to sports data.</p>
    </article>

    <!-- 4. Automation Lab -->
    <article class="cell cell-placeholder glow-box-hover" aria-label="Automation Lab - coming soon">
      <span class="soon">Coming Soon</span>
      <span class="tag tag-purple">⚙️ Automation</span>
      <h2 class="cell-title" style="font-size:16px">Automation Lab</h2>
      <p class="cell-desc">Workflow automation tools, scrapers, and data pipeline prototypes.</p>
    </article>

    <!-- 5. Data Stories -->
    <article class="cell cell-placeholder glow-box-hover" aria-label="Data Stories - coming soon">
      <span class="soon">Coming Soon</span>
      <span class="tag tag-pink">📊 Data</span>
      <h2 class="cell-title" style="font-size:16px">Data Stories</h2>
      <p class="cell-desc">Interactive visualisations and deep dives into football statistics and simulation outputs.</p>
    </article>

    <!-- 6. Blog - full-width strip -->
    <article class="cell cell-blog" style="padding:20px 24px" aria-label="BapLab Blog - Lab Notes">
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px">
        <div>
          <span class="tag tag-cy">✍️ Lab Notes</span>
          <h2 class="cell-title" style="font-size:15px;margin-bottom:4px">Latest from the Lab</h2>
          <p class="cell-desc" style="font-size:12px">Analysis, guides, and updates on simulations, AI experiments, and data science.</p>
        </div>
        <a href="/blog/" class="cta-btn cta-ghost" aria-label="Read the BapLab blog">
          Read Blog
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </article>

  </main>

  <!-- Footer (no FIFA disclaimer on homepage) -->
  <footer class="lab-footer">
    <div style="margin-bottom:6px">
      <a href="/">BapLab</a> ·
      <a href="/world-cup-2026-simulator/" target="_blank" rel="noopener noreferrer">Simulator</a> ·
      <a href="/blog/">Blog</a> ·
      <a href="https://www.patreon.com/c/BapLab" target="_blank" rel="noopener noreferrer">Patreon</a> ·
      <a href="mailto:baplab.net@gmail.com">Contact Us</a>
    </div>
    <div>© 2026 BapLab</div>
  </footer>

</body>
</html>
