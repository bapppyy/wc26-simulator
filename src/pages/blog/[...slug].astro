---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props:  { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{post.data.title} — WC 2026 Simulator</title>
    <meta name="description" content={post.data.description} />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #fafaf8; color: #1a1a1a; line-height: 1.7; }
      .wrap { max-width: 720px; margin: 0 auto; padding: 32px 16px 80px; }
      .back { display:inline-flex;align-items:center;gap:5px;font-size:13px;color:#555;text-decoration:none;margin-bottom:28px; }
      .back:hover { color:#1a1a1a; }
      .meta { font-size: 11px; color: #aaa; margin-bottom: 8px; text-transform: uppercase; letter-spacing: .06em; }
      h1 { font-size: 24px; font-weight: 700; margin-bottom: 10px; line-height: 1.3; }
      .desc { font-size: 15px; color: #555; margin-bottom: 32px; padding-bottom: 24px; border-bottom: 1px solid #eee; }
      .content h2 { font-size: 17px; font-weight: 700; margin: 28px 0 10px; }
      .content h3 { font-size: 14px; font-weight: 700; margin: 20px 0 6px; }
      .content p  { font-size: 14px; margin-bottom: 14px; color: #333; }
      .content ul, .content ol { font-size: 14px; margin-bottom: 14px; padding-left: 22px; color: #333; }
      .content li { margin-bottom: 5px; }
      .content strong { font-weight: 700; }
      .content code { font-family: monospace; background: #f3f3f0; border-radius: 3px; padding: 1px 5px; font-size: 12px; }
      .content pre { background: #f3f3f0; border-radius: 8px; padding: 16px; overflow-x: auto; margin-bottom: 14px; }
      .content pre code { background: none; padding: 0; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <a class="back" href="/blog/">← All posts</a>
      <div class="meta">
        {post.data.type} · {post.data.pubDate.toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' })}
      </div>
      <h1>{post.data.title}</h1>
      <div class="desc">{post.data.description}</div>
      <div class="content">
        <Content />
      </div>
    </div>
  </body>
</html>
