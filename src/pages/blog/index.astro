---
import { getCollection } from 'astro:content';
import { defaultLang } from '../../i18n/ui';

const lang = defaultLang;
const allPosts = await getCollection('blog', ({ data }) =>
  data.lang === lang && !data.draft
);
const posts = allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Blog — WC 2026 Simulator</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #fafaf8; color: #1a1a1a; line-height: 1.6; }
      .wrap { max-width: 720px; margin: 0 auto; padding: 32px 16px 80px; }
      .back { display:inline-flex;align-items:center;gap:5px;font-size:13px;color:#555;text-decoration:none;margin-bottom:28px; }
      .back:hover { color:#1a1a1a; }
      h1 { font-size: 22px; font-weight: 700; margin-bottom: 6px; }
      .subt { font-size: 13px; color: #888; margin-bottom: 32px; }
      .post { background: #fff; border: 1px solid #eee; border-radius: 12px; padding: 20px 22px; margin-bottom: 14px; text-decoration: none; color: inherit; display: block; transition: box-shadow .15s; }
      .post:hover { box-shadow: 0 2px 12px rgba(0,0,0,.07); }
      .post-type { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: #3b82f6; margin-bottom: 6px; }
      .post-title { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
      .post-desc { font-size: 13px; color: #555; margin-bottom: 10px; }
      .post-date { font-size: 11px; color: #aaa; }
      .empty { color: #888; font-size: 14px; text-align: center; padding: 40px 0; }
    </style>
  </head>
  <body>
    <div class="wrap">
      <a class="back" href="/">← Back to Simulator</a>
      <h1>WC 2026 Simulator Blog</h1>
      <div class="subt">Analysis, guides, and updates</div>

      {posts.length === 0
        ? <div class="empty">No posts yet — check back soon.</div>
        : posts.map(post => (
          <a class="post" href={`/blog/${post.id}/`}>
            <div class="post-type">{post.data.type}</div>
            <div class="post-title">{post.data.title}</div>
            <div class="post-desc">{post.data.description}</div>
            <div class="post-date">{post.data.pubDate.toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' })}</div>
          </a>
        ))
      }
    </div>
  </body>
</html>
