---
---
<div class="tbar">
  <select class="sel" id="nSel">
    <option value="200">200 sim.</option>
    <option value="500">500 sim.</option>
    <option value="1000" selected>1000 sim.</option>
    <option value="2000">2000 sim.</option>
    <option value="5000" id="opt5000">5000 sim.</option>
  </select>
  <button class="btn pr" data-i18n="sim.simulate" id="runBtn" onclick="runAll()">Simulate</button>
<span id="info" style="font-size:12px;color:#888"></span>
</div>
<div class="upset-ctrl">
  <label data-i18n="sim.upset">Upset Factor:</label>
  <span data-i18n="sim.few" style="font-size:12px;color:#888">Few</span>
  <input type="range" min="10" max="50" step="5" value="15" id="upexSlider" oninput="updateUpex(this.value)" style="cursor:pointer">
  <span data-i18n="sim.many" style="font-size:12px;color:#888">Many</span>
</div>

<script>
  // Remove 5000 sim option on narrow screens
  function capSimOptions() {
    const opt = document.getElementById('opt5000') as HTMLOptionElement | null;
    if (!opt) return;
    if (window.innerWidth < 768) {
      const sel = opt.closest('select') as HTMLSelectElement | null;
      if (sel && sel.value === '5000') sel.value = '2000';
      opt.remove();
    }
  }
  capSimOptions();
  window.addEventListener('resize', capSimOptions, { passive: true });
</script>
