---
---
<div class="phdr">
  <a href="/" aria-label="BapLab home" style="display:inline-flex;align-items:center;flex-shrink:0">
    <img src="/logo-wide.png" alt="BapLab" class="h-8 object-contain" style="height:2rem;object-fit:contain" />
  </a>
  <div style="display:flex;align-items:center;gap:8px">
    <button id="obBadge" class="ob-badge" onclick="obOpen()" style="display:none">
      <span id="obBadgeFlag"></span><span id="obBadgeName"></span><span style="color:#aaa;font-size:11px">↺</span>
    </button>
    <button id="obSelectBtn" class="ob-badge" onclick="obOpen()" data-i18n="header.selectTeam" style="font-size:12px;padding:4px 10px">Select Team</button>
    <select id="langSel" class="sel" style="font-size:12px;padding:4px 6px" aria-label="Language">
      <option value="en">🌐 English</option>
      <option value="es">🌐 Español</option>
      <option value="fr">🌐 Français</option>
      <option value="de">🌐 Deutsch</option>
      <option value="pt">🌐 Português</option>
      <option value="ja">🌐 日本語</option>
      <option value="ko">🌐 한국어</option>
      <option value="ar">🌐 العربية</option>
      <option value="tr">🌐 Türkçe</option>
    </select>
    <button class="btn" data-i18n="header.how" onclick="openHow()">How It Works?</button>
  </div>
</div>

<script>
  import { ui, defaultLang, rtlLangs } from '../i18n/ui';
  type Lang = keyof typeof ui;

  function applyLang(lang: Lang) {
    const dict = ui[lang] as Record<string, string>;

    // Apply translated text to all data-i18n elements
    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n');
      if (key && dict[key] != null) el.textContent = dict[key];
    });

    // Apply translated placeholders
    document.querySelectorAll<HTMLInputElement>('[data-i18n-placeholder]').forEach(el => {
      const key = el.getAttribute('data-i18n-placeholder');
      if (key && dict[key] != null) el.placeholder = dict[key];
    });

    // Handle RTL direction
    const html = document.documentElement;
    if (rtlLangs.has(lang)) {
      html.setAttribute('dir', 'rtl');
      html.setAttribute('lang', lang);
    } else {
      html.setAttribute('dir', 'ltr');
      html.setAttribute('lang', lang);
    }
  }

  function initLang() {
    const saved = (localStorage.getItem('wc26_lang') || defaultLang) as Lang;
    const sel = document.getElementById('langSel') as HTMLSelectElement | null;
    if (sel) sel.value = saved;
    applyLang(saved);

    sel?.addEventListener('change', () => {
      const val = sel.value as Lang;
      localStorage.setItem('wc26_lang', val);
      applyLang(val);
      // Re-render JS-built panels so tTeam() picks up new language
      (window as any).refreshPanels?.();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLang);
  } else {
    initLang();
  }
</script>
