---
---
<div id="obBg" class="ob-bg">
  <div class="ob-modal">
    <div class="ob-hdr">
      <div class="ob-title">Pick Your Team</div>
      <div class="ob-sub">Which team are you supporting in the 2026 FIFA World Cup? All data will be highlighted for your team.</div>
    </div>
    <div class="ob-search">
      <input id="obSearch" class="ob-search-inp" type="text" placeholder="Search teams...">
    </div>
    <div class="ob-list" id="obList"></div>
    <div class="ob-footer">
      <button class="ob-rand" id="obRandBtn">🎲 Random Team</button>
      <div style="display:flex;gap:8px">
        <button class="ob-skip" id="obSkipBtn">Skip →</button>
        <button class="ob-ok" id="obOkBtn" disabled>Continue →</button>
      </div>
    </div>
  </div>
</div>
